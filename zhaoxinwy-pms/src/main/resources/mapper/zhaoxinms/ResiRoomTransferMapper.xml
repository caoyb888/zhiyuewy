<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zhaoxinms.resi.archive.mapper.ResiRoomTransferMapper">

    <resultMap type="com.zhaoxinms.resi.archive.entity.ResiRoomTransfer" id="ResiRoomTransferResult">
        <id property="id" column="id"/>
        <result property="projectId" column="project_id"/>
        <result property="roomId" column="room_id"/>
        <result property="oldCustomerId" column="old_customer_id"/>
        <result property="newCustomerId" column="new_customer_id"/>
        <result property="transferDate" column="transfer_date"/>
        <result property="transferRemark" column="transfer_remark"/>
        <result property="operator" column="operator"/>
        <result property="createTime" column="create_time"/>
        <result property="roomName" column="room_name"/>
        <result property="oldCustomerName" column="old_customer_name"/>
        <result property="newCustomerName" column="new_customer_name"/>
        <result property="projectName" column="project_name"/>
    </resultMap>

    <sql id="selectResiRoomTransferVo">
        SELECT t.id, t.project_id, t.room_id, t.old_customer_id, t.new_customer_id,
               t.transfer_date, t.transfer_remark, t.operator, t.create_time,
               r.room_alias as room_name,
               oc.customer_name as old_customer_name,
               nc.customer_name as new_customer_name,
               p.name as project_name
        FROM resi_room_transfer t
        LEFT JOIN resi_room r ON t.room_id = r.id
        LEFT JOIN resi_customer oc ON t.old_customer_id = oc.id
        LEFT JOIN resi_customer nc ON t.new_customer_id = nc.id
        LEFT JOIN resi_project p ON t.project_id = p.id
    </sql>

    <select id="selectTransferList" resultMap="ResiRoomTransferResult">
        <include refid="selectResiRoomTransferVo"/>
        WHERE 1 = 1
        <if test="projectId != null">
            AND t.project_id = #{projectId}
        </if>
        <if test="projectIds != null and projectIds.size() > 0">
            AND t.project_id IN
            <foreach collection="projectIds" item="pid" open="(" separator="," close=")">
                #{pid}
            </foreach>
        </if>
        <if test="roomId != null">
            AND t.room_id = #{roomId}
        </if>
        <if test="startDate != null and startDate != ''">
            AND t.transfer_date &gt;= #{startDate}
        </if>
        <if test="endDate != null and endDate != ''">
            AND t.transfer_date &lt;= #{endDate}
        </if>
        ORDER BY t.create_time DESC
    </select>

    <select id="selectTransferByRoomId" resultMap="ResiRoomTransferResult">
        <include refid="selectResiRoomTransferVo"/>
        WHERE t.room_id = #{roomId}
        ORDER BY t.transfer_date DESC
    </select>

</mapper>
