<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zhaoxinms.resi.archive.mapper.ResiCustomerMapper">

    <resultMap type="com.zhaoxinms.resi.archive.entity.ResiCustomer" id="ResiCustomerResult">
        <id property="id" column="id"/>
        <result property="projectId" column="project_id"/>
        <result property="customerName" column="customer_name"/>
        <result property="phone" column="phone"/>
        <result property="idCard" column="id_card"/>
        <result property="gender" column="gender"/>
        <result property="customerType" column="customer_type"/>
        <result property="openid" column="openid"/>
        <result property="enabledMark" column="enabled_mark"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <select id="selectResiCustomerList" resultMap="ResiCustomerResult">
        SELECT id, project_id, customer_name, phone, id_card, gender, customer_type, openid,
               enabled_mark, create_by, create_time, update_by, update_time
        FROM resi_customer
        WHERE enabled_mark = 1
        <if test="projectId != null">
            AND project_id = #{projectId}
        </if>
        <if test="projectIds != null and projectIds.size() > 0">
            AND project_id IN
            <foreach collection="projectIds" item="pid" open="(" separator="," close=")">
                #{pid}
            </foreach>
        </if>
        <if test="customerName != null and customerName != ''">
            AND customer_name LIKE CONCAT('%', #{customerName}, '%')
        </if>
        <if test="phone != null and phone != ''">
            AND phone LIKE CONCAT('%', #{phone}, '%')
        </if>
        <if test="customerType != null">
            AND customer_type = #{customerType}
        </if>
        ORDER BY create_time DESC
    </select>

</mapper>
