<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zhaoxinms.resi.archive.mapper.ResiMeterDeviceMapper">

    <resultMap type="com.zhaoxinms.resi.archive.entity.ResiMeterDevice" id="ResiMeterDeviceResult">
        <id property="id" column="id"/>
        <result property="projectId" column="project_id"/>
        <result property="roomId" column="room_id"/>
        <result property="meterCode" column="meter_code"/>
        <result property="meterType" column="meter_type"/>
        <result property="installDate" column="install_date"/>
        <result property="initReading" column="init_reading"/>
        <result property="multiplier" column="multiplier"/>
        <result property="isPublic" column="is_public"/>
        <result property="publicGroup" column="public_group"/>
        <result property="enabledMark" column="enabled_mark"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="roomName" column="room_name"/>
    </resultMap>

    <sql id="selectResiMeterDeviceVo">
        SELECT d.id, d.project_id, d.room_id, d.meter_code, d.meter_type,
               d.install_date, d.init_reading, d.multiplier, d.is_public, d.public_group,
               d.enabled_mark, d.create_by, d.create_time, d.update_by, d.update_time,
               r.room_alias as room_name
        FROM resi_meter_device d
        LEFT JOIN resi_room r ON d.room_id = r.id AND r.enabled_mark = 1
    </sql>

    <select id="selectResiMeterDeviceList" resultMap="ResiMeterDeviceResult">
        <include refid="selectResiMeterDeviceVo"/>
        WHERE d.enabled_mark = 1
        <if test="projectId != null">
            AND d.project_id = #{projectId}
        </if>
        <if test="projectIds != null and projectIds.size() > 0">
            AND d.project_id IN
            <foreach collection="projectIds" item="pid" open="(" separator="," close=")">
                #{pid}
            </foreach>
        </if>
        <if test="roomId != null">
            AND d.room_id = #{roomId}
        </if>
        <if test="meterCode != null and meterCode != ''">
            AND d.meter_code LIKE CONCAT('%', #{meterCode}, '%')
        </if>
        <if test="meterType != null">
            AND d.meter_type = #{meterType}
        </if>
        <if test="isPublic != null">
            AND d.is_public = #{isPublic}
        </if>
        <if test="publicGroup != null and publicGroup != ''">
            AND d.public_group = #{publicGroup}
        </if>
        ORDER BY d.create_time DESC
    </select>

</mapper>
